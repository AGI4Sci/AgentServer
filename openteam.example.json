{
  "llm": {
    "baseUrl": "http://127.0.0.1:3888/v1",
    "apiKey": "replace-with-your-api-key",
    "model": "replace-with-your-model",
    "fallbacks": []
  },
  "runtime": {
    "worker": {
      "idleTtlMs": 900000,
      "idleSweepMs": 60000,
      "gatewayStartTimeoutMs": 120000,
      "runStallTimeoutMs": 120000
    },
    "executor": {
      "reportGraceMs": 180000,
      "deliveryTimeoutMs": 90000,
      "toolDeliveryTimeoutMs": 240000
    },
    "localDev": {
      "toolMaxSteps": 12,
      "sourceTaskToolMaxSteps": 20,
      "sourceTaskLocalExplorationSoftLimit": 6,
      "forceSummaryOnBudgetExhausted": true,
      "sourceTaskForceSummaryOnBudgetExhausted": true
    },
    "workspace": {
      "mode": "server",
      "serverAllowedRoots": [],
      "workspaces": [
        {
          "id": "server-work",
          "root": "/opt/agent-server/workspaces",
          "ownerWorker": "server-local"
        },
        {
          "id": "gpu-exp",
          "root": "/home/ubuntu/experiments/run-001",
          "artifactRoot": "/home/ubuntu/experiments/run-001/artifacts",
          "ownerWorker": "gpu-a100"
        }
      ],
      "workers": [
        {
          "id": "backend-server",
          "kind": "backend-server",
          "capabilities": ["network", "metadata"]
        },
        {
          "id": "server-local",
          "kind": "server",
          "allowedRoots": ["/opt/agent-server/workspaces"],
          "capabilities": ["filesystem", "shell", "network", "metadata"]
        },
        {
          "id": "gpu-a100",
          "kind": "ssh",
          "host": "gpu.example.com",
          "user": "ubuntu",
          "port": 22,
          "identityFile": "/opt/agent-server/ssh/id_ed25519",
          "allowedRoots": ["/home/ubuntu/experiments"],
          "capabilities": ["filesystem", "shell", "gpu"]
        },
        {
          "id": "mac-local",
          "kind": "client-worker",
          "endpoint": "http://127.0.0.1:3457",
          "authToken": "change-me-client-worker-token",
          "allowedRoots": ["/Applications/workspace"],
          "capabilities": ["filesystem", "shell", "network"]
        }
      ],
      "toolRouting": {
        "default": {
          "primary": "server-local"
        },
        "rules": [
          {
            "tools": ["web_search", "web_fetch"],
            "primary": "backend-server",
            "fallbacks": ["mac-local"]
          }
        ]
      }
    },
    "codex": {
      "launchHealthcheckTimeoutMs": 20000
    }
  }
}
