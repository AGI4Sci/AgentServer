{
  "name": "@agi4sci/agent-server",
  "version": "0.1.0",
  "description": "Standalone AgentServer runtime and backend adapter layer extracted from OpenTeam Studio.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "server/backend/openteam_agent/",
    "openteam.example.json",
    "README.md",
    "PROJECT.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:8080": "PORT=8080 npm run dev",
    "build": "tsc",
    "build:backend-binaries": "node --import tsx scripts/build-openteam-backends.ts",
    "check:deployment": "node --import tsx scripts/check-deployment.ts",
    "client-worker": "node --import tsx scripts/client-worker.ts",
    "prune:backend-artifacts": "node --import tsx scripts/prune-backend-build-artifacts.ts",
    "start": "node dist/server/index.js",
    "runtime-supervisor": "node --import tsx server/runtime-supervisor/index.ts",
    "smoke:agent-server": "node --import tsx scripts/smoke-agent-server.ts",
    "smoke:agent-server:backends": "node --import tsx scripts/smoke-agent-server-backends.ts",
    "smoke:agent-server:tool-matrix": "node --import tsx scripts/smoke-agent-server-tool-matrix.ts",
    "smoke:agent-sdk": "node --import tsx scripts/smoke-agent-sdk.ts",
    "smoke:agent-sdk:all-backends": "node --import tsx scripts/smoke-agent-sdk-all-backends.ts",
    "smoke:agent-sdk:installed": "node --import tsx scripts/smoke-agent-sdk-installed.ts",
    "smoke:openteam-agent": "node --import tsx scripts/smoke-openteam-agent-backend.ts",
    "smoke:client-worker": "node --import tsx scripts/smoke-client-worker-service.ts",
    "smoke:deployment-workers": "node --import tsx scripts/smoke-deployment-worker-routing.ts",
    "smoke:ssh-workers": "node --import tsx scripts/smoke-ssh-workers.ts",
    "smoke:tool-executor": "node --import tsx scripts/smoke-tool-executor.ts",
    "smoke:tool-routing-config": "node --import tsx scripts/smoke-tool-routing-config.ts",
    "smoke:workspace-policy": "node --import tsx scripts/smoke-workspace-policy.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.12.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
