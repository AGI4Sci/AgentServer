# AgentServer strategic agent-backend readiness environment.
# Copy values into your shell or local env manager. Do not commit real secrets.
#
# Suggested local file name:
#   .agent-backend-readiness.local.env
# Then run:
#   npm run check:agent-backend-adapters:ready

# Optional: limit readiness checks to a subset.
# Values: codex, claude-code, gemini, self-hosted-agent
# AGENT_SERVER_LIVE_ADAPTER_SMOKE_BACKENDS=codex,claude-code,gemini,self-hosted-agent

# Claude Code bridge and self-hosted agent use an OpenAI-compatible endpoint.
# These env vars override openteam.json for adapter preflight and runtime.
AGENT_SERVER_ADAPTER_LLM_BASE_URL=http://127.0.0.1:3888/v1
AGENT_SERVER_ADAPTER_LLM_API_KEY=replace-with-your-api-key
AGENT_SERVER_ADAPTER_LLM_MODEL=replace-with-your-model
# AGENT_SERVER_ADAPTER_LLM_PROVIDER=openai-compatible

# Gemini needs one auth source. Prefer AgentServer-scoped names so the local
# readiness file stays the single source of truth; the adapter maps them to the
# official Gemini/Google env names before starting the SDK.
# AGENT_SERVER_GEMINI_API_KEY=replace-with-your-gemini-api-key
# AGENT_SERVER_GOOGLE_API_KEY=replace-with-your-google-api-key
# AGENT_SERVER_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-application-credentials.json
# AGENT_SERVER_GEMINI_CLI_HOME=/Users/you

# Codex defaults to gpt-5.4 for readiness because gpt-5.2-codex may be listed
# but rejected by the current ChatGPT account path.
AGENT_SERVER_CODEX_MODEL=gpt-5.4
AGENT_SERVER_CODEX_EFFORT=medium

# Inspect the readiness plan without starting backends.
# AGENT_SERVER_ADAPTER_READINESS_DRY_RUN=1
